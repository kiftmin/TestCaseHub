{
  "name": "testcasehub",
  "private": true,
  "version": "1.0.0",
  "description": "TestCaseHub - UAT Test Case Management System",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:seed": "pnpm --filter db seed",
    "db:studio": "pnpm --filter db studio",
    "api:dev": "pnpm --filter api-server dev",
    "api:build": "pnpm --filter api-server build",
    "api:start": "pnpm --filter api-server start",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "lib/*",
    "artifacts/*"
  ]
}
